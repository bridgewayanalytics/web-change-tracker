# web-change-tracker environment template
# Copy to .env and adjust for your run

# Playwright (1=enabled, 0=requests only)
USE_PLAYWRIGHT=1

# Targets
# TARGETS_FILE=targets.json
# TARGET_IDS=id1,id2   # comma-separated; omit to process all

# State backend: local (state.json) or dynamodb
# STATE_BACKEND=local
# STATE_TABLE=web-change-tracker-state   # required when STATE_BACKEND=dynamodb

# Change log: set to append events to S3
# CHANGELOG_BUCKET=my-changelog-bucket
# CHANGELOG_PREFIX=changelog/   # default

# HTML snapshot archival: set to archive raw HTML of every fetched page to S3
# HTML_SNAPSHOT_BUCKET=my-snapshot-bucket

# Hardening
MAX_RETRIES=3
BACKOFF_SECONDS=2
DELAY_BETWEEN_PAGES=1

# Email (SES)
# SEND_EMAIL=false
# DRY_RUN=true
# SES_REGION=us-east-1
# FROM_EMAIL=verified@example.com
# TO_EMAILS=alerts@yourdomain.com,Amnon.Levy@bridgewayanalytics.com

# Bubble (for reference enrichment, E2E snapshot, resolver smoke)
# BUBBLE_API_URL=https://your-app.bubbleapps.io/live/api/1.1/obj
# BUBBLE_API_KEY=your-bubble-data-api-key
# BUBBLE_ALERTS_ENABLED=false  # set true + --no-dry-run-bubble to write alerts to Bubble

# Chatkit (document-data-extraction agent for agenda items + Chronicle topics)
# CHATKIT_API_URL=https://chat-api.bridgewayanalytics.com
# CHATKIT_JWT_TOKEN=your-jwt-token-here
# CHATKIT_TIMEOUT=60

# Page change snapshots: store before/after stripped HTML to S3 on each detected change
# PAGE_CHANGE_SNAPSHOT_BUCKET=my-snapshot-bucket  # falls back to HTML_SNAPSHOT_BUCKET if unset

# Page change agent: LLM-based extraction from before/after HTML snapshots
# PAGE_CHANGE_AGENT_ENABLED=false
# PAGE_CHANGE_AGENT_MODEL=gpt-4o   # defaults to OPENAI_MODEL if unset

# AWS (when using DynamoDB, S3, or SES)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
