[
  {
    "id": "life_rbc_wg",
    "label": "Life RBC Working Group",
    "type": "series",
    "url": "https://content.naic.org/committees/e/life-risk-based-capital-wg",
    "extract": [
      {
        "type": "docs",
        "extractor": "link_collector_v1",
        "params": { "extensions": [".pdf"], "allow_domains": ["content.naic.org"] },
        "_purpose": "Track newly posted call materials and PDFs."
      },
      {
        "type": "event_links",
        "extractor": "keyword_links_v1",
        "params": { "keywords": ["meeting", "agenda", "materials", "call"], "allow_domains": ["content.naic.org"] },
        "_purpose": "Track links related to meetings and agendas."
      }
    ]
  },
  {
    "id": "naic_events",
    "label": "NAIC Public Events",
    "type": "events",
    "url": "https://content.naic.org/events",
    "extract": [
      {
        "type": "events",
        "extractor": "naic_events_v1",
        "params": { "allow_domains": ["content.naic.org"] },
        "_purpose": "Track newly listed NAIC events and changes to scheduled events."
      }
    ]
  }
]
