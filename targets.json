    "type": "series",
    "url": "https://example.com",
    "extract": [
      {
        "type": "events",
        "extractor": "naic_events_v1",
        "params": {},
        "_purpose": "NAIC-specific event/meeting extraction (title, datetime, url)."
      }
    ]
  }
]
